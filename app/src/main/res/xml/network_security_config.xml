<?xml version="1.0" encoding="utf-8"?>
<!-- Com networkSecurityConfig, usesCleartextTraffic no manifest é ignorado.
     Sem cleartext no base-config, só hosts nomeados em <domain-config> funcionam em HTTP/WS;
     IP LAN (192.168.*) não casa e o aparelho físico bloqueia ws:// — parece “não conecta”. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
